+# Licensed under a 3-clause BSD style license - see LICENSE.rst
+"""Direct transformations between ITRS and observed coordinate frames."""
+
+import numpy as np
+
+from astropy import units as u
+from astropy.coordinates.baseframe import frame_transform_graph
+from astropy.coordinates.matrix_utilities import matrix_transpose, rotation_matrix
+from astropy.coordinates.transformations import FunctionTransformWithFiniteDifference
+
+from .altaz import AltAz
+from .hadec import HADec
+from .itrs import ITRS
+from .utils import PIOVER2
+
+
+def itrs_to_observed_mat(observed_frame):
+    """Return the rotation matrix from ITRS to an observed frame."""
+    lon, lat, _ = observed_frame.location.to_geodetic("WGS84")
+    elong = lon.to_value(u.radian)
+
+    if isinstance(observed_frame, AltAz):
+        # AltAz is left handed: azimuth increases from north through east.
+        minus_x = np.eye(3)
+        minus_x[0, 0] = -1.0
+        return (minus_x
+                @ rotation_matrix(PIOVER2 - lat.to_value(u.radian), "y",
+                                  unit=u.radian)
+                @ rotation_matrix(elong, "z", unit=u.radian))
+
+    # HADec is left handed: hour angle increases westward.
+    minus_y = np.eye(3)
+    minus_y[1, 1] = -1.0
+    return minus_y @ rotation_matrix(elong, "z", unit=u.radian)
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, AltAz)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, HADec)
+def itrs_to_observed(itrs_coo, observed_frame):
+    """Transform an ITRS coordinate to topocentric AltAz or HADec."""
+    # An ITRS position is tied to the rotating Earth.  In particular, do not
+    # synchronize obstimes through an ITRS self-transform, which would move a
+    # nearby terrestrial object with respect to the solar-system barycenter.
+    topocentric = (itrs_coo.cartesian
+                   - observed_frame.location.get_itrs().cartesian)
+    rep = topocentric.transform(itrs_to_observed_mat(observed_frame))
+    return observed_frame.realize_frame(rep)
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, AltAz, ITRS)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, HADec, ITRS)
+def observed_to_itrs(observed_coo, itrs_frame):
+    """Transform a topocentric AltAz or HADec coordinate to ITRS."""
+    topocentric = observed_coo.cartesian.transform(
+        matrix_transpose(itrs_to_observed_mat(observed_coo)))
+    rep = topocentric + observed_coo.location.get_itrs().cartesian
+    return itrs_frame.realize_frame(rep)
