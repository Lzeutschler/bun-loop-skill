+@pytest.mark.parametrize("observed_cls", [AltAz, HADec])
+@pytest.mark.parametrize("obstime", [None, Time("J2007")])
+def test_direct_itrs_observed_geometry(observed_cls, obstime):
+    location = EarthLocation.from_geodetic(23*u.deg, 47*u.deg, 350*u.m)
+    lon, lat = location.lon.to_value(u.rad), location.lat.to_value(u.rad)
+    up = CartesianRepresentation(np.cos(lat)*np.cos(lon),
+                                 np.cos(lat)*np.sin(lon), np.sin(lat))
+    frame = observed_cls(location=location, obstime=obstime)
+    unit_direction = UnitSphericalRepresentation(lon=lon*u.rad, lat=lat*u.rad)
+    direction = ITRS(unit_direction, obstime=Time("J2020")).transform_to(frame)
+    if observed_cls is AltAz:
+        assert_allclose(direction.alt, 90*u.deg, atol=1*u.narcsec)
+    else:
+        assert_allclose(direction.ha, 0*u.deg, atol=1*u.narcsec)
+        assert_allclose(direction.dec, location.lat, atol=1*u.narcsec)
+    direction_back = direction.transform_to(ITRS(obstime=None))
+    assert_allclose(direction_back.cartesian.xyz, up.xyz, atol=1e-14*u.one)
+    assert direction_back.obstime is None
+
+    position = location.get_itrs(obstime=obstime).cartesian + up * (2*u.km)
+    observed = ITRS(position, obstime=Time("J1990")).transform_to(frame)
+    assert_allclose(observed.distance, 2*u.km, atol=1*u.nm)
+    position_back = observed.transform_to(ITRS(obstime=None))
+    assert_allclose(position_back.cartesian.xyz, position.xyz, atol=1*u.nm)
+
