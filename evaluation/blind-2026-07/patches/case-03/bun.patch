+@pytest.mark.parametrize("observed_cls", [AltAz, HADec])
+def test_direct_itrs_observed_refraction_against_cirs_erfa(observed_cls):
+    """Check direct refraction against the established ERFA observed path."""
+    location = EarthLocation.from_geodetic(-70*u.deg, 25*u.deg)
+    time = Time("J2015")
+    vacuum_altaz = AltAz(az=[37, 123, 251]*u.deg, alt=[5, 20, 65]*u.deg,
+                         obstime=time, location=location)
+    itrs = vacuum_altaz.transform_to(ITRS(obstime=time))
+    vacuum = itrs.transform_to(observed_cls(obstime=time, location=location))
+    apparent_frame = observed_cls(
+        obstime=time, location=location, pressure=800*u.hPa,
+        temperature=10*u.deg_C, relative_humidity=0.5,
+        obswl=0.55*u.micron)
+
+    direct = itrs.transform_to(apparent_frame)
+    # CIRS<->observed uses ERFA atioq/atoiq and is independent of the new edge.
+    oracle = vacuum.transform_to(CIRS(obstime=time, location=location)).transform_to(
+        apparent_frame)
+    assert_allclose(direct.spherical.lon, oracle.spherical.lon,
+                    atol=2*u.narcsec)
+    assert_allclose(direct.spherical.lat, oracle.spherical.lat,
+                    atol=2*u.narcsec)
+
+    direct_back = direct.transform_to(ITRS(obstime=time))
+    assert_allclose(direct_back.cartesian.xyz, itrs.cartesian.xyz,
+                    atol=2e-12*u.one)
