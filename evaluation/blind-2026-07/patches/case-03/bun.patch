+def test_direct_itrs_altaz_refraction_and_vector_differential():
+    location = EarthLocation.from_geodetic(-70*u.deg, 25*u.deg)
+    time = Time("J2015")
+    vacuum = AltAz(az=[20, 120]*u.deg, alt=[20, 45]*u.deg,
+                   distance=[1, 2]*u.km, obstime=time, location=location)
+    itrs = vacuum.transform_to(ITRS(obstime=Time("J2000")))
+    refracted = itrs.transform_to(AltAz(obstime=time, location=location,
+                                        pressure=800*u.hPa))
+    assert np.all(refracted.alt > vacuum.alt)
+
+    cart = itrs.cartesian.with_differentials(
+        CartesianDifferential([1, 2]*u.m/u.s, [3, 4]*u.m/u.s,
+                              [5, 6]*u.m/u.s))
+    moving = ITRS(cart, obstime=time).transform_to(
+        AltAz(obstime=None, location=location))
+    roundtrip = moving.transform_to(ITRS(obstime=None))
+    assert_allclose(roundtrip.cartesian.xyz, cart.xyz, atol=1*u.nm)
+    assert_allclose(roundtrip.velocity.d_xyz, cart.differentials["s"].d_xyz,
+                    atol=1*u.nm/u.s)
+
+    moving_refracted = ITRS(cart, obstime=time).transform_to(
+        AltAz(obstime=None, location=location, pressure=800*u.hPa))
+    refracted_roundtrip = moving_refracted.transform_to(ITRS(obstime=None))
+    assert_allclose(refracted_roundtrip.cartesian.xyz, cart.xyz,
+                    atol=1*u.nm)
+    assert_allclose(refracted_roundtrip.velocity.d_xyz,
+                    cart.differentials["s"].d_xyz, atol=1*u.um/u.s)
+
