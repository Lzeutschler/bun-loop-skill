+@pytest.mark.parametrize("observed_cls", [AltAz, HADec])
+def test_direct_itrs_observed_refraction_arrays_without_time(observed_cls):
+    location = EarthLocation.from_geodetic(-70*u.deg, 25*u.deg)
+    if observed_cls is AltAz:
+        vacuum = AltAz(az=[20, 120]*u.deg, alt=[20, 45]*u.deg,
+                       obstime=None, location=location)
+    else:
+        vacuum = HADec(ha=[-30, 20]*u.deg, dec=[5, 35]*u.deg,
+                       obstime=None, location=location)
+
+    itrs = vacuum.transform_to(ITRS(obstime=None))
+    apparent_frame = observed_cls(
+        obstime=None, location=location, pressure=[0, 800]*u.hPa,
+        temperature=[10, 10]*u.deg_C,
+        relative_humidity=[0.5, 0.5], obswl=[0.55, 0.55]*u.micron)
+    apparent = itrs.transform_to(apparent_frame)
+
+    if observed_cls is AltAz:
+        vacuum_alt = vacuum.alt
+        apparent_alt = apparent.alt
+        assert_allclose(apparent.az, vacuum.az, atol=1*u.narcsec)
+    else:
+        lat = location.lat
+        vacuum_alt = np.arcsin(
+            np.sin(lat) * np.sin(vacuum.dec)
+            + np.cos(lat) * np.cos(vacuum.dec) * np.cos(vacuum.ha))
+        apparent_alt = np.arcsin(
+            np.sin(lat) * np.sin(apparent.dec)
+            + np.cos(lat) * np.cos(apparent.dec) * np.cos(apparent.ha))
+
+    assert_allclose(apparent_alt[0], vacuum_alt[0], atol=1*u.narcsec)
+    assert apparent_alt[1] > vacuum_alt[1]
+    roundtrip = apparent.transform_to(ITRS(obstime=None))
+    assert_allclose(roundtrip.cartesian.xyz, itrs.cartesian.xyz, atol=2e-12*u.one)
+
