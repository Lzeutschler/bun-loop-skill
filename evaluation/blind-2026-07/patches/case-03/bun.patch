+@pytest.mark.parametrize("observed_cls", [AltAz, HADec])
+def test_direct_itrs_observed_refraction_broadcast_expansion(observed_cls):
+    location = EarthLocation.from_geodetic(-70*u.deg, 25*u.deg)
+    vacuum_altaz = AltAz(az=73*u.deg, alt=18*u.deg,
+                         obstime=None, location=location)
+    itrs = vacuum_altaz.transform_to(ITRS(obstime=None))
+    vacuum = itrs.transform_to(observed_cls(obstime=None, location=location))
+    apparent = itrs.transform_to(observed_cls(
+        obstime=None, location=location, pressure=[0, 400, 800]*u.hPa))
+
+    assert apparent.shape == (3,)
+    roundtrip = apparent.transform_to(ITRS(obstime=None))
+    expected = np.broadcast_to(itrs.cartesian.xyz[:, np.newaxis], (3, 3),
+                               subok=True)
+    assert_allclose(roundtrip.cartesian.xyz, expected, atol=2e-12*u.one)
+    if observed_cls is AltAz:
+        assert_allclose(apparent.az, vacuum.az, atol=1*u.narcsec)
+
