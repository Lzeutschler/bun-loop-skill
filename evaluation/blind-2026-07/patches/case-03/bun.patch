+def test_direct_itrs_observed_graph_edges():
+    for source, target in ((ITRS, AltAz), (ITRS, HADec),
+                           (AltAz, ITRS), (HADec, ITRS)):
+        assert len(frame_transform_graph.get_transform(source, target).transforms) == 1
+
