+# Licensed under a 3-clause BSD style license - see LICENSE.rst
+"""Transformations between ITRS and topocentric observed frames."""
+
+import numpy as np
+import erfa
+
+from astropy import units as u
+
+from astropy.coordinates.baseframe import frame_transform_graph
+from astropy.coordinates.matrix_utilities import matrix_transpose
+from astropy.coordinates.representation import CartesianRepresentation
+from astropy.coordinates.transformations import FunctionTransformWithFiniteDifference
+
+from .altaz import AltAz
+from .hadec import HADec
+from .itrs import ITRS
+
+
+def _itrs_to_observed_mat(observed_frame):
+    """Return the terrestrial-to-local Cartesian matrix.
+
+    The matrix is built from geodetic longitude and latitude, so unlike the
+    celestial intermediate matrices it needs no time.  AltAz Cartesian axes
+    are north, east, and up.  HADec axes point along the local meridian,
+    westward, and toward the terrestrial north pole.
+    """
+    lon = observed_frame.location.lon.to_value(u.radian)
+    lat = observed_frame.location.lat.to_value(u.radian)
+    lon, lat = np.broadcast_arrays(lon, lat)
+    slon, clon = np.sin(lon), np.cos(lon)
+    slat, clat = np.sin(lat), np.cos(lat)
+
+    mat = np.empty(lon.shape + (3, 3))
+    if isinstance(observed_frame, AltAz):
+        mat[..., 0, :] = np.stack((-slat * clon, -slat * slon, clat), axis=-1)
+        mat[..., 1, :] = np.stack((-slon, clon, np.zeros_like(clon)), axis=-1)
+        mat[..., 2, :] = np.stack((clat * clon, clat * slon, slat), axis=-1)
+    else:
+        mat[..., 0, :] = np.stack((clon, slon, np.zeros_like(clon)), axis=-1)
+        mat[..., 1, :] = np.stack((slon, -clon, np.zeros_like(clon)), axis=-1)
+        mat[..., 2, :] = np.stack((np.zeros_like(clon), np.zeros_like(clon),
+                                   np.ones_like(clon)), axis=-1)
+    return mat
+
+
+def _has_length(coo):
+    """Whether a coordinate is a physical position rather than a direction."""
+    return coo.cartesian.x.unit.is_equivalent(u.m)
+
+
+def _translate(cartesian, observer, operation):
+    """Translate a Cartesian representation without dropping differentials."""
+    differentials = cartesian.differentials
+    translated = operation(cartesian.without_differentials(), observer)
+    return translated.with_differentials(differentials)
+
+
+def _altaz_mat(observed_frame):
+    """Terrestrial-to-AltAz matrix, including for an HADec frame."""
+    if isinstance(observed_frame, AltAz):
+        return _itrs_to_observed_mat(observed_frame)
+    return _itrs_to_observed_mat(
+        AltAz(location=observed_frame.location, obstime=observed_frame.obstime))
+
+
+def _refract_altaz(cartesian, observed_frame, inverse=False):
+    """Apply or remove ERFA refraction from local AltAz Cartesian data."""
+    pressure, temperature, humidity, wavelength = np.broadcast_arrays(
+        observed_frame.pressure.to_value(u.hPa),
+        observed_frame.temperature.to_value(u.deg_C),
+        observed_frame.relative_humidity.value,
+        observed_frame.obswl.to_value(u.micron),
+    )
+    refa, refb = erfa.refco(pressure, temperature, humidity, wavelength)
+
+    xyz = cartesian.xyz
+    distance = np.sqrt(np.sum(xyz * xyz, axis=0))
+    az = np.arctan2(xyz[1], xyz[0])
+    zenith = np.arctan2(np.hypot(xyz[0], xyz[1]), xyz[2])
+    distance, az, zenith, refa, refb = np.broadcast_arrays(
+        distance, az, zenith, refa, refb)
+    if inverse:
+        # REFZ maps unrefracted to observed zenith distance.  Its derivative
+        # is close to unity, so fixed-point inversion converges rapidly while
+        # retaining REFZ's well-behaved low-altitude limiting convention.
+        observed_zenith = zenith
+        for _ in range(5):
+            zenith = zenith + observed_zenith - erfa.refz(zenith, refa, refb)
+    else:
+        zenith = erfa.refz(zenith, refa, refb)
+
+    sinzen = np.sin(zenith)
+    return CartesianRepresentation(
+        distance * sinzen * np.cos(az),
+        distance * sinzen * np.sin(az),
+        distance * np.cos(zenith), copy=False)
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, AltAz,
+                                 finite_difference_frameattr_name=None)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, HADec,
+                                 finite_difference_frameattr_name=None)
+def itrs_to_observed(itrs_coo, observed_frame):
+    """Transform an ITRS position to an observed frame geometrically.
+
+    ITRS coordinates are treated as Earth-fixed positions.  In particular, we
+    must not transform them to a different obstime through a celestial frame:
+    that would interpret a terrestrial position as an object moving through
+    the solar system.
+    """
+    topocentric_itrs = itrs_coo.cartesian
+    if _has_length(itrs_coo):
+        observer = observed_frame.location.get_itrs(
+            obstime=observed_frame.obstime).cartesian
+        topocentric_itrs = _translate(topocentric_itrs, observer,
+                                      lambda position, origin: position - origin)
+
+    if np.all(observed_frame.pressure == 0):
+        return observed_frame.realize_frame(
+            topocentric_itrs.transform(_itrs_to_observed_mat(observed_frame)))
+
+    altaz_mat = _altaz_mat(observed_frame)
+    local_altaz = topocentric_itrs.transform(altaz_mat)
+    refracted_altaz = _refract_altaz(local_altaz, observed_frame)
+    if isinstance(observed_frame, HADec):
+        refracted_itrs = refracted_altaz.transform(matrix_transpose(altaz_mat))
+        result = refracted_itrs.transform(_itrs_to_observed_mat(observed_frame))
+    else:
+        result = refracted_altaz
+    return observed_frame.realize_frame(result)
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, AltAz, ITRS,
+                                 finite_difference_frameattr_name=None)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, HADec, ITRS,
+                                 finite_difference_frameattr_name=None)
+def observed_to_itrs(observed_coo, itrs_frame):
+    """Transform a topocentric observed coordinate directly to ITRS."""
+    if np.all(observed_coo.pressure == 0):
+        topocentric_itrs = observed_coo.cartesian.transform(
+            matrix_transpose(_itrs_to_observed_mat(observed_coo)))
+        if _has_length(observed_coo):
+            observer = observed_coo.location.get_itrs(
+                obstime=observed_coo.obstime).cartesian
+            topocentric_itrs = _translate(
+                topocentric_itrs, observer,
+                lambda position, origin: position + origin)
+        return itrs_frame.realize_frame(topocentric_itrs)
+
+    altaz_mat = _altaz_mat(observed_coo)
+    if isinstance(observed_coo, HADec):
+        local_itrs = observed_coo.cartesian.transform(
+            matrix_transpose(_itrs_to_observed_mat(observed_coo)))
+        local_altaz = local_itrs.transform(altaz_mat)
+    else:
+        local_altaz = observed_coo.cartesian
+    unrefracted_altaz = _refract_altaz(local_altaz, observed_coo, inverse=True)
+    topocentric_itrs = unrefracted_altaz.transform(matrix_transpose(altaz_mat))
+    if _has_length(observed_coo):
+        observer = observed_coo.location.get_itrs(
+            obstime=observed_coo.obstime).cartesian
+        topocentric_itrs = _translate(
+            topocentric_itrs, observer,
+            lambda position, origin: position + origin)
+    return itrs_frame.realize_frame(topocentric_itrs)
