+        (0, t <= 1), (1, t >= 5),
+        (2*asin(sqrt(t/4 - Rational(1, 4)))/pi, True))
+    assert cdf(Dagum('D', 2, 3, 4))(t) == Piecewise(
+        (t**6/(4096*(t**3/64 + 1)**2), t > 0), (0, True))
+    assert cdf(Frechet('F', 2, 3, 1))(t) == Piecewise(
+        (exp(-((t - 1)/3)**-2), t > 1), (0, True))
+
+    g = cdf(Gamma('G', 3, 2))(t)
+    assert g == Piecewise((lowergamma(3, t/2)/2, t > 0), (0, True))
+    # Erlang shares GammaDistribution and must preserve exact rates.
+    assert cdf(Erlang('Erl', 3, 2))(t) == Piecewise(
+        (lowergamma(3, 2*t)/2, t > 0), (0, True))
+    assert cdf(GammaInverse('GI', 3, 2))(t) == Piecewise(
+        (uppergamma(3, 2/t)/2, t > 0), (0, True))
+
+    assert cdf(Kumaraswamy('K', 2, 3))(t) == Piecewise(
+        (0, t <= 0), (1, t >= 1), (1 - (1 - t**2)**3, True))
+    assert cdf(Laplace('L', 1, 2))(t) == Piecewise(
+        (exp((t - 1)/2)/2, t <= 1),
+        (1 - exp(-(t - 1)/2)/2, True))
