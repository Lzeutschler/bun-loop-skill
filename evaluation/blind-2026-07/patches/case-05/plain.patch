+def _split_regex_csv(value: str) -> Sequence[str]:
+    """Split comma-separated regexes without splitting inside regex constructs."""
+    patterns: list[str] = []
+    start = 0
+    escaped = False
+    delimiters: list[str] = []
+    matching_delimiters = {"(": ")", "[": "]", "{": "}"}
+
+    for index, character in enumerate(value):
+        if escaped:
+            escaped = False
+            continue
+        if character == "\\":
+            escaped = True
+            continue
+        if delimiters and delimiters[-1] == "]":
+            if character == "]":
+                delimiters.pop()
+        elif character in matching_delimiters:
+            delimiters.append(matching_delimiters[character])
+        elif delimiters and character == delimiters[-1]:
+            delimiters.pop()
+        elif character == "," and not delimiters:
+            if pattern := value[start:index].strip():
+                patterns.append(pattern)
+            start = index + 1
+
+    if pattern := value[start:].strip():
+        patterns.append(pattern)
+    return patterns
+
+
 def _regexp_csv_transfomer(value: str) -> Sequence[Pattern[str]]:
     """Transforms a comma separated list of regular expressions."""
