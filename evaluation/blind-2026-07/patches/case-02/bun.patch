+    def _stringify(self, transform: StringifyTransform) -> str:
+        return transform(self.literal) + transform(self.suffix)
+
+    def get_id(self, version: int) -> str:
+        if version == 1:
+            raise NoOldIdError()
+        # A user-defined literal is a call to its literal operator.
+        return ('clli' + self.suffix.get_id(version)
+                + self.literal.get_id(version) + 'E')
