+    def test_mark_decorator_multiple_baseclasses_merged_in_mro_order(
+        self, pytester: Pytester
+    ) -> None:
+        pytester.makepyfile(
+            """
+            import pytest
+
+            @pytest.mark.m("root")
+            class Root: pass
+
+            @pytest.mark.m("foo")
+            class Foo(Root): pass
+
+            @pytest.mark.m("bar")
+            class Bar(Root): pass
+
+            @pytest.mark.m("test")
+            class TestClass(Foo, Bar):
+                def test_mark_order(self, request):
+                    assert [
+                        mark.args[0] for mark in request.node.iter_markers("m")
+                    ] == ["root", "bar", "foo", "test"]
+            """
+        )
+
+        result = pytester.runpytest()
+
+        result.assert_outcomes(passed=1)
+
+    def test_marks_with_metaclass_overriding_class_introspection(
+        self, pytester: Pytester
+    ) -> None:
+        path = pytester.makepyfile(
+            """
+            import pytest
+
+            class Meta(type):
+                pytestmark = pytest.mark.m("meta")
+
+                def __getattribute__(cls, name):
+                    if name == "pytestmark":
+                        return pytest.mark.m("dynamic-spoof")
+                    if name == "__mro__":
+                        return ()
+                    if name == "__dict__":
+                        namespace = dict(type.__getattribute__(cls, name))
+                        namespace["pytestmark"] = pytest.mark.m("spoof")
+                        return namespace
+                    return super().__getattribute__(name)
+
+            @pytest.mark.m("base")
+            class Base: pass
+
+            @pytest.mark.m("class")
+            class TestClass(Base, metaclass=Meta):
+                def test_marks(self): pass
+            """
+        )
+
+        items, _ = pytester.inline_genitems(path)
+
+        assert [mark.args[0] for mark in items[0].iter_markers("m")] == [
+            "meta",
+            "base",
+            "class",
+        ]
+
