-    String::from_utf8_lossy(&bytes[bytes.len().saturating_sub(count)..]).into_owned()
+pub fn run(input: &str, count: f64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let len = chars.len();
+    let relative_start = -count;
+
+    let start = if relative_start.is_nan()
+        || relative_start == 0.0
+        || relative_start == f64::NEG_INFINITY
+    {
+        0
+    } else if relative_start == f64::INFINITY {
+        len
+    } else {
+        let integer = relative_start.trunc();
+        if integer < 0.0 {
+            let magnitude = -integer;
+            if magnitude >= len as f64 {
+                0
+            } else {
+                len - magnitude as usize
+            }
+        } else if integer >= len as f64 {
+            len
+        } else {
+            integer as usize
+        }
+    };
+
+    chars[start..].iter().collect()
 }
