+fn is_js_whitespace(ch: char) -> bool {
+    matches!(
+        ch,
+        '\u{0009}'
+            | '\u{000a}'
+            | '\u{000b}'
+            | '\u{000c}'
+            | '\u{000d}'
+            | '\u{0020}'
+            | '\u{00a0}'
+            | '\u{1680}'
+            | '\u{2000}'..='\u{200a}'
+            | '\u{2028}'
+            | '\u{2029}'
+            | '\u{202f}'
+            | '\u{205f}'
+            | '\u{3000}'
+            | '\u{feff}'
+    )
+}
+
+fn is_decimal_number(value: &str) -> bool {
+    let bytes = value.as_bytes();
+    let mut index = 0;
+
+    if matches!(bytes.get(index), Some(b'+' | b'-')) {
+        index += 1;
+    }
+
+    let integer_start = index;
+    while matches!(bytes.get(index), Some(b'0'..=b'9')) {
+        index += 1;
+    }
+    let has_integer_digits = index > integer_start;
+
+    let mut has_fraction_digits = false;
+    if bytes.get(index) == Some(&b'.') {
+        index += 1;
+        let fraction_start = index;
+        while matches!(bytes.get(index), Some(b'0'..=b'9')) {
+            index += 1;
+        }
+        has_fraction_digits = index > fraction_start;
+    }
+
+    if !has_integer_digits && !has_fraction_digits {
+        return false;
+    }
+
+    if matches!(bytes.get(index), Some(b'e' | b'E')) {
+        index += 1;
+        if matches!(bytes.get(index), Some(b'+' | b'-')) {
+            index += 1;
+        }
+        let exponent_start = index;
+        while matches!(bytes.get(index), Some(b'0'..=b'9')) {
+            index += 1;
+        }
+        if index == exponent_start {
+            return false;
+        }
+    }
+
+    index == bytes.len()
+}
+
+fn parse_power_of_two_integer(digits: &str, radix: u32, bits_per_digit: u32) -> f64 {
+    let mut significand = 0_u64;
+    let mut bit_length = 0_usize;
+    let mut round_bit = false;
+    let mut sticky_bit = false;
+    let mut started = false;
+
+    for ch in digits.chars() {
+        let Some(digit) = ch.to_digit(radix) else {
+            return f64::NAN;
+        };
+
+        for bit_index in (0..bits_per_digit).rev() {
+            let bit = (digit >> bit_index) & 1;
+            if !started && bit == 0 {
+                continue;
+            }
+            started = true;
+
+            match bit_length {
+                0..=52 => significand = (significand << 1) | u64::from(bit),
+                53 => round_bit = bit != 0,
+                _ => sticky_bit |= bit != 0,
+            }
+            bit_length = bit_length.saturating_add(1);
+        }
+    }
+
+    if !started {
+        return 0.0;
+    }
+    if bit_length <= 53 {
+        return significand as f64;
+    }
+
+    if round_bit && (sticky_bit || significand & 1 != 0) {
+        significand += 1;
+        if significand == 1_u64 << 53 {
+            significand >>= 1;
+            bit_length = bit_length.saturating_add(1);
+        }
+    }
+
+    if bit_length > 1024 {
+        return f64::INFINITY;
+    }
+
+    let exponent = (bit_length as u64 - 1 + 1023) << 52;
+    let fraction = significand & ((1_u64 << 52) - 1);
+    f64::from_bits(exponent | fraction)
+}
+
+fn parse_js_number(value: Option<&str>) -> f64 {
+    let Some(value) = value else {
+        return f64::NAN;
+    };
+    let value = value.trim_matches(is_js_whitespace);
+
+    if value.is_empty() {
+        return 0.0;
+    }
+    match value {
+        "Infinity" | "+Infinity" => return f64::INFINITY,
+        "-Infinity" => return f64::NEG_INFINITY,
+        _ => {}
+    }
+
+    if let Some(digits) = value.strip_prefix("0x").or_else(|| value.strip_prefix("0X")) {
+        return if digits.is_empty() {
+            f64::NAN
+        } else {
+            parse_power_of_two_integer(digits, 16, 4)
+        };
+    }
+    if let Some(digits) = value.strip_prefix("0o").or_else(|| value.strip_prefix("0O")) {
+        return if digits.is_empty() {
+            f64::NAN
+        } else {
+            parse_power_of_two_integer(digits, 8, 3)
+        };
+    }
+    if let Some(digits) = value.strip_prefix("0b").or_else(|| value.strip_prefix("0B")) {
+        return if digits.is_empty() {
+            f64::NAN
+        } else {
+            parse_power_of_two_integer(digits, 2, 1)
+        };
+    }
+
+    if is_decimal_number(value) {
+        value.parse::<f64>().unwrap_or(f64::NAN)
+    } else {
+        f64::NAN
+    }
+}
