-pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+fn slice_index(index: i128, len: i128) -> usize {
+    if index < 0 {
+        (len + index).max(0) as usize
+    } else {
+        index.min(len) as usize
+    }
+}
+
+pub fn run(input: &str, start: i64, count: i64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let len = chars.len() as i128;
+    let begin = slice_index(start as i128, len);
+    let end = slice_index(start as i128 + count as i128, len);
+
+    if end <= begin {
+        String::new()
+    } else {
+        chars[begin..end].iter().collect()
+    }
 }
diff --git a/port/src/ops/wrap_index.rs b/port/src/ops/wrap_index.rs
index abc3ff4..45877fd 100644
--- a/port/src/ops/wrap_index.rs
+++ b/port/src/ops/wrap_index.rs
@@ -1 +1,12 @@
-pub fn run(value: i64, size: i64) -> i64 { value % size }
+pub fn run(value: i64, size: i64) -> i64 {
+    if size == -1 {
+        return 0;
+    }
+
+    let remainder = value % size;
+    if (size > 0 && remainder < 0) || (size < 0 && remainder > 0) {
+        remainder + size
+    } else {
+        remainder
+    }
+}
