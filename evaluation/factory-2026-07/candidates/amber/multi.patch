 pub fn run(input: &str) -> Vec<String> {
-    input.split(';').map(|entry| {
-        let (key, value) = entry.split_once('=').unwrap_or((entry, ""));
-        format!("{key}:{value}")
-    }).collect()
+    super::escaped_fields::run(input, ';')
+        .into_iter()
+        .map(|entry| {
+            let mut pair = super::escaped_fields::run(&entry, '=').into_iter();
+            let key = pair.next().unwrap_or_default();
+            format!("{key}:{}", pair.collect::<Vec<_>>().join("="))
+        })
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn parses_escaped_pairs() {
+        assert_eq!(
+            run("name=amber;note=left\\=right;empty="),
+            ["name:amber", "note:left=right", "empty:"]
+        );
+    }
+
+    #[test]
+    fn keeps_escaped_semicolons_in_an_entry() {
+        assert_eq!(run("note=left\\;right;flag"), ["note:left;right", "flag:"]);
+    }
+
+    #[test]
+    fn rejoins_all_value_segments() {
+        assert_eq!(run("key=one=two"), ["key:one=two"]);
+    }
 }
diff --git a/port/src/ops/floor_bucket.rs b/port/src/ops/floor_bucket.rs
