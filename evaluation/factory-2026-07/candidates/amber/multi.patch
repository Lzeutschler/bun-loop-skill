diff --git a/port/src/ops/escaped_fields.rs b/port/src/ops/escaped_fields.rs
index a56fc45..59d90ec 100644
--- a/port/src/ops/escaped_fields.rs
+++ b/port/src/ops/escaped_fields.rs
@@ -1,3 +1,75 @@
-pub fn run(input: &str, delimiter: char) -> Vec<String> {
-    input.split(delimiter).map(str::to_owned).collect()
+pub trait Delimiter {
+    fn single_char(self) -> Option<char>;
+}
+
+impl Delimiter for char {
+    fn single_char(self) -> Option<char> {
+        Some(self)
+    }
+}
+
+impl Delimiter for &str {
+    fn single_char(self) -> Option<char> {
+        let mut chars = self.chars();
+        let delimiter = chars.next()?;
+        chars.next().is_none().then_some(delimiter)
+    }
+}
+
+pub fn run(input: &str, delimiter: impl Delimiter) -> Vec<String> {
+    let delimiter = delimiter.single_char();
+    let mut result = Vec::new();
+    let mut current = String::new();
+    let mut escaped = false;
+
+    for ch in input.chars() {
+        if escaped {
+            current.push(ch);
+            escaped = false;
+        } else if ch == '\\' {
+            escaped = true;
+        } else if Some(ch) == delimiter {
+            result.push(current);
+            current = String::new();
+        } else {
+            current.push(ch);
+        }
+    }
+
+    if escaped {
+        current.push('\\');
+    }
+    result.push(current);
+    result
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn splits_and_unescapes_fields() {
+        assert_eq!(run("one|two\\|inner|amber", '|'), ["one", "two|inner", "amber"]);
+    }
+
+    #[test]
+    fn preserves_empty_fields_and_a_trailing_escape() {
+        assert_eq!(run("|amber|tail\\", '|'), ["", "amber", "tail\\"]);
+    }
+
+    #[test]
+    fn backslash_remains_the_escape_marker_when_used_as_delimiter() {
+        assert_eq!(run("a\\b\\", '\\'), ["ab\\"]);
+    }
+
+    #[test]
+    fn empty_and_multi_character_delimiters_do_not_split() {
+        assert_eq!(run("a|b", ""), ["a|b"]);
+        assert_eq!(run("a||b", "||"), ["a||b"]);
+    }
+
+    #[test]
+    fn a_single_multi_byte_character_can_be_the_delimiter() {
+        assert_eq!(run("one🙂two\\🙂inner🙂three", "🙂"), ["one", "two🙂inner", "three"]);
+    }
 }
