+}
+
+pub fn stringify(value: f64) -> String {
+    if !value.is_finite() {
+        return "null".to_owned();
+    }
+    if value == 0.0 {
+        return "0".to_owned();
+    }
+
+    // `Display` supplies the shortest decimal that round-trips to this f64.
+    // Re-layout those digits using Number::toString's notation boundaries;
+    // fixed precision formatting would instead expose the exact binary integer.
+    let negative = value.is_sign_negative();
+    let rendered = value.abs().to_string();
+    let (mantissa, exponent) = rendered
+        .split_once('e')
+        .or_else(|| rendered.split_once('E'))
+        .map_or((rendered.as_str(), 0), |(mantissa, exponent)| {
+            (mantissa, exponent.parse::<i32>().unwrap())
+        });
+
+    let decimal_point = mantissa.find('.').unwrap_or(mantissa.len()) as i32;
+    let mut digits: String = mantissa.chars().filter(|&ch| ch != '.').collect();
+    let leading_zeroes = digits.bytes().position(|digit| digit != b'0').unwrap();
+    digits.drain(..leading_zeroes);
+    while digits.ends_with('0') {
+        digits.pop();
+    }
+
+    let digit_count = digits.len() as i32;
+    let decimal_position = decimal_point + exponent - leading_zeroes as i32;
+    let mut result = String::new();
+    if negative {
+        result.push('-');
+    }
+
+    if digit_count <= decimal_position && decimal_position <= 21 {
+        result.push_str(&digits);
+        result.extend(std::iter::repeat('0').take((decimal_position - digit_count) as usize));
+    } else if 0 < decimal_position && decimal_position <= 21 {
+        let decimal_position = decimal_position as usize;
+        result.push_str(&digits[..decimal_position]);
+        result.push('.');
+        result.push_str(&digits[decimal_position..]);
+    } else if -6 < decimal_position && decimal_position <= 0 {
+        result.push_str("0.");
+        result.extend(std::iter::repeat('0').take((-decimal_position) as usize));
+        result.push_str(&digits);
+    } else {
+        result.push_str(&digits[..1]);
+        if digits.len() > 1 {
+            result.push('.');
+            result.push_str(&digits[1..]);
+        }
+        result.push('e');
+        let exponent = decimal_position - 1;
+        if exponent >= 0 {
+            result.push('+');
+        }
+        result.push_str(&exponent.to_string());
+    }
+
+    result
+}
+
+fn parse_number(input: &str) -> f64 {
+    let input = input.trim_matches(is_js_whitespace);
+    if input.is_empty() {
+        return 0.0;
+    }
+
+    match input {
+        "Infinity" | "+Infinity" => return f64::INFINITY,
+        "-Infinity" => return f64::NEG_INFINITY,
+        _ => {}
+    }
+
+    if let Some(digits) = input.strip_prefix("0x").or_else(|| input.strip_prefix("0X")) {
+        return parse_power_of_two_integer(digits, 4, hex_digit);
+    }
+    if let Some(digits) = input.strip_prefix("0o").or_else(|| input.strip_prefix("0O")) {
+        return parse_power_of_two_integer(digits, 3, octal_digit);
+    }
+    if let Some(digits) = input.strip_prefix("0b").or_else(|| input.strip_prefix("0B")) {
+        return parse_power_of_two_integer(digits, 1, binary_digit);
+    }
+
+    if !is_decimal_literal(input) {
+        return f64::NAN;
+    }
+    input.parse().unwrap_or(f64::NAN)
+}
+
+fn is_js_whitespace(ch: char) -> bool {
+    matches!(
+        ch,
+        '\u{0009}'
+            | '\u{000a}'
+            | '\u{000b}'
+            | '\u{000c}'
+            | '\u{000d}'
+            | '\u{0020}'
+            | '\u{00a0}'
+            | '\u{1680}'
+            | '\u{2000}'..='\u{200a}'
+            | '\u{2028}'
+            | '\u{2029}'
+            | '\u{202f}'
+            | '\u{205f}'
+            | '\u{3000}'
+            | '\u{feff}'
+    )
+}
+
+fn is_decimal_literal(input: &str) -> bool {
+    let bytes = input.as_bytes();
+    let mut cursor = usize::from(matches!(bytes.first(), Some(b'+') | Some(b'-')));
+    let integer_start = cursor;
+    while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+        cursor += 1;
+    }
+    let integer_digits = cursor - integer_start;
+
+    let mut fractional_digits = 0;
+    if bytes.get(cursor) == Some(&b'.') {
+        cursor += 1;
+        let fractional_start = cursor;
+        while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+            cursor += 1;
+        }
+        fractional_digits = cursor - fractional_start;
+    }
+    if integer_digits + fractional_digits == 0 {
+        return false;
+    }
+
+    if matches!(bytes.get(cursor), Some(b'e') | Some(b'E')) {
+        cursor += 1;
+        if matches!(bytes.get(cursor), Some(b'+') | Some(b'-')) {
+            cursor += 1;
+        }
+        let exponent_start = cursor;
+        while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+            cursor += 1;
+        }
+        if cursor == exponent_start {
+            return false;
+        }
+    }
+
+    cursor == bytes.len()
+}
+
+fn binary_digit(byte: u8) -> Option<u8> {
+    (b'0'..=b'1').contains(&byte).then_some(byte - b'0')
+}
+
+fn octal_digit(byte: u8) -> Option<u8> {
+    (b'0'..=b'7').contains(&byte).then_some(byte - b'0')
+}
+
+fn hex_digit(byte: u8) -> Option<u8> {
+    match byte {
+        b'0'..=b'9' => Some(byte - b'0'),
+        b'a'..=b'f' => Some(byte - b'a' + 10),
+        b'A'..=b'F' => Some(byte - b'A' + 10),
+        _ => None,
+    }
+}
+
+fn parse_power_of_two_integer(
+    digits: &str,
+    bits_per_digit: usize,
+    decode: fn(u8) -> Option<u8>,
+) -> f64 {
+    if digits.is_empty() {
+        return f64::NAN;
+    }
+
+    let mut decoded = Vec::with_capacity(digits.len());
+    for byte in digits.bytes() {
+        let Some(digit) = decode(byte) else {
+            return f64::NAN;
+        };
+        decoded.push(digit);
+    }
+
+    let Some(first_index) = decoded.iter().position(|&digit| digit != 0) else {
+        return 0.0;
+    };
+    let first = decoded[first_index];
+    let first_bits = u8::BITS as usize - first.leading_zeros() as usize;
+    let bit_length = first_bits + (decoded.len() - first_index - 1) * bits_per_digit;
+    if bit_length > 1024 {
+        return f64::INFINITY;
+    }
+
+    let mut significand = 0_u64;
+    let mut significant_index = 0_usize;
+    let mut round_bit = false;
+    let mut sticky = false;
+    for (offset, &digit) in decoded[first_index..].iter().enumerate() {
+        let high_bit = if offset == 0 {
+            first_bits - 1
+        } else {
+            bits_per_digit - 1
+        };
+        for bit in (0..=high_bit).rev() {
+            let set = digit & (1 << bit) != 0;
+            match significant_index {
+                0..=52 => significand = (significand << 1) | u64::from(set),
+                53 => round_bit = set,
+                _ => sticky |= set,
+            }
+            significant_index += 1;
+        }
+    }
+
+    if bit_length <= 53 {
+        return significand as f64;
+    }
+    if round_bit && (sticky || significand & 1 != 0) {
+        significand += 1;
+    }
+
+    let mut rounded_bit_length = bit_length;
+    if significand == 1_u64 << 53 {
+        significand >>= 1;
+        rounded_bit_length += 1;
+    }
+    if rounded_bit_length > 1024 {
+        return f64::INFINITY;
+    }
+
+    significand as f64 * 2_f64.powi(rounded_bit_length as i32 - 53)
+}
