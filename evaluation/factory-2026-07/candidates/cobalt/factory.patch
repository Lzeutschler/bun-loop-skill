+pub fn run(input: &str, count: f64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let length = chars.len();
+
+    let start = if count.is_nan() || count == 0.0 || count == f64::INFINITY {
+        0
+    } else if count == f64::NEG_INFINITY {
+        length
+    } else if count > 0.0 {
+        if count >= length as f64 {
+            0
+        } else {
+            length - count as usize
+        }
+    } else {
+        let start = -count;
+        if start >= length as f64 {
+            length
+        } else {
+            start as usize
+        }
+    };
+
+    chars[start..].iter().collect()
 }
