+// Binary, octal, and hexadecimal integer literals are powers-of-two radices. Reading
+// their leading 53 bits plus a guard and sticky bit reproduces Number's rounding
+// without needing an arbitrary-precision integer dependency.
+fn parse_radix_integer(digits: &str, radix_bits: usize, radix: u8) -> Option<f64> {
+    if digits.is_empty() {
+        return None;
+    }
+
+    let mut values = Vec::with_capacity(digits.len());
+    for byte in digits.bytes() {
+        let value = digit_value(byte)?;
+        if value >= radix {
+            return None;
+        }
+        values.push(value);
+    }
+
+    let Some(first_nonzero) = values.iter().position(|&value| value != 0) else {
+        return Some(0.0);
+    };
+    let first = values[first_nonzero];
+    let first_bits = (u8::BITS - first.leading_zeros()) as usize;
+    let bit_length = first_bits + (values.len() - first_nonzero - 1) * radix_bits;
+
+    let mut leading = 0_u64;
+    let mut seen = 0_usize;
+    let mut guard = false;
+    let mut sticky = false;
+    for (position, &value) in values[first_nonzero..].iter().enumerate() {
+        let width = if position == 0 { first_bits } else { radix_bits };
+        for shift in (0..width).rev() {
+            let bit = (value >> shift) & 1 != 0;
+            if seen < 53 {
+                leading = (leading << 1) | u64::from(bit);
+            } else if seen == 53 {
+                guard = bit;
+            } else {
+                sticky |= bit;
+            }
+            seen += 1;
+        }
+    }
+
+    if bit_length <= 53 {
+        return Some(leading as f64);
+    }
+
+    if guard && (sticky || leading & 1 != 0) {
+        leading += 1;
+    }
+
+    let mut exponent = bit_length - 1;
+    if leading == 1_u64 << 53 {
+        leading >>= 1;
+        exponent += 1;
+    }
+    if exponent > 1023 {
+        return Some(f64::INFINITY);
+    }
+
+    let fraction = leading - (1_u64 << 52);
+    Some(f64::from_bits(
+        (((exponent as u64) + 1023) << 52) | fraction,
+    ))
+}
+
+fn js_number(value: &str) -> f64 {
+    let value = value.trim_matches(is_js_whitespace);
+    if value.is_empty() {
+        return 0.0;
+    }
+    match value {
+        "Infinity" | "+Infinity" => return f64::INFINITY,
+        "-Infinity" => return f64::NEG_INFINITY,
+        _ => {}
+    }
+
+    if let Some(digits) = value
+        .strip_prefix("0b")
+        .or_else(|| value.strip_prefix("0B"))
+    {
+        return parse_radix_integer(digits, 1, 2).unwrap_or(f64::NAN);
+    }
+    if let Some(digits) = value
+        .strip_prefix("0o")
+        .or_else(|| value.strip_prefix("0O"))
+    {
+        return parse_radix_integer(digits, 3, 8).unwrap_or(f64::NAN);
+    }
+    if let Some(digits) = value
+        .strip_prefix("0x")
+        .or_else(|| value.strip_prefix("0X"))
+    {
+        return parse_radix_integer(digits, 4, 16).unwrap_or(f64::NAN);
+    }
+
+    if is_decimal_literal(value) {
+        value.parse().unwrap_or(f64::NAN)
+    } else {
+        f64::NAN
+    }
+}
+
+fn slice_index(value: f64, length: usize) -> usize {
+    if value.is_nan() || value == 0.0 {
+        return 0;
+    }
+    if value == f64::NEG_INFINITY {
+        return 0;
+    }
+    if value == f64::INFINITY {
+        return length;
+    }
+
+    let integer = value.trunc();
+    let length_number = length as f64;
+    if integer < 0.0 {
+        if integer <= -length_number {
+            0
+        } else {
+            (length_number + integer) as usize
+        }
+    } else if integer >= length_number {
+        length
+    } else {
+        integer as usize
+    }
+}
+
+pub fn run(input: &str, start: &str, count: &str) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let start = js_number(start);
+    let end = start + js_number(count);
+    let begin = slice_index(start, chars.len());
+    let end = slice_index(end, chars.len());
+
+    if end <= begin {
+        String::new()
+    } else {
+        chars[begin..end].iter().collect()
+    }
 }
