@@ -1,4 +1,16 @@
-pub fn run(input: &str, count: usize) -> String {
-    let bytes = input.as_bytes();
-    String::from_utf8_lossy(&bytes[bytes.len().saturating_sub(count)..]).into_owned()
+pub fn run(input: &str, count: f64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let index = if count.is_nan() { -0.0 } else { -count.trunc() };
+    let len_as_number = chars.len() as f64;
+    let begin = if index < 0.0 {
+        if index <= -len_as_number {
+            0
+        } else {
+            (len_as_number + index) as usize
+        }
+    } else {
+        index.min(len_as_number) as usize
+    };
+
+    chars[begin..].iter().collect()
 }
diff --git a/port/src/ops/window.rs b/port/src/ops/window.rs
index 11e6f16..af1bb02 100644
--- a/port/src/ops/window.rs
+++ b/port/src/ops/window.rs
@@ -1,5 +1,25 @@
-pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+fn slice_index(index: f64, len: usize) -> usize {
+    let index = if index.is_nan() { 0.0 } else { index.trunc() };
+    let len_as_number = len as f64;
+    if index < 0.0 {
+        if index <= -len_as_number {
+            0
+        } else {
+            (len_as_number + index) as usize
+        }
+    } else {
+        index.min(len_as_number) as usize
+    }
+}
+
+pub fn run(input: &str, start: f64, count: f64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let begin = slice_index(start, chars.len());
+    let end = slice_index(start + count, chars.len());
+
+    if end <= begin {
+        String::new()
+    } else {
+        chars[begin..end].iter().collect()
+    }
 }
