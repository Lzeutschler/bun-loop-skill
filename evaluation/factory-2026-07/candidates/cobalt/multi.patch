+++ b/port/src/ops/escaped_fields.rs
@@ -1,3 +1,32 @@
-pub fn run(input: &str, delimiter: char) -> Vec<String> {
-    input.split(delimiter).map(str::to_owned).collect()
+pub fn run(input: &str, delimiter: &str) -> Vec<String> {
+    let delimiter = {
+        let mut chars = delimiter.chars();
+        match (chars.next(), chars.next()) {
+            (Some(delimiter), None) => Some(delimiter),
+            _ => None,
+        }
+    };
+    let mut result = Vec::new();
+    let mut current = String::new();
+    let mut escaped = false;
+
+    for ch in input.chars() {
+        if escaped {
+            current.push(ch);
+            escaped = false;
+        } else if ch == '\\' {
+            escaped = true;
+        } else if Some(ch) == delimiter {
+            result.push(current);
+            current = String::new();
+        } else {
+            current.push(ch);
+        }
+    }
+
+    if escaped {
+        current.push('\\');
+    }
+    result.push(current);
+    result
 }
