+fn parse_number(value: &str) -> f64 {
+    fn is_js_whitespace(ch: char) -> bool {
+        matches!(
+            ch,
+            '\u{0009}'..='\u{000d}'
+                | '\u{0020}'
+                | '\u{00a0}'
+                | '\u{1680}'
+                | '\u{2000}'..='\u{200a}'
+                | '\u{2028}'
+                | '\u{2029}'
+                | '\u{202f}'
+                | '\u{205f}'
+                | '\u{3000}'
+                | '\u{feff}'
+        )
+    }
+
+    let value = value.trim_matches(is_js_whitespace);
+    if value.is_empty() {
+        return 0.0;
+    }
+    match value {
+        "Infinity" | "+Infinity" => return f64::INFINITY,
+        "-Infinity" => return f64::NEG_INFINITY,
+        _ => {}
+    }
+
+    let (radix, digits) =
+        if let Some(digits) = value.strip_prefix("0x").or_else(|| value.strip_prefix("0X")) {
+            (16, digits)
+        } else if let Some(digits) = value.strip_prefix("0o").or_else(|| value.strip_prefix("0O")) {
+            (8, digits)
+        } else if let Some(digits) = value.strip_prefix("0b").or_else(|| value.strip_prefix("0B")) {
+            (2, digits)
+        } else {
+            let bytes = value.as_bytes();
+            let mut cursor = usize::from(matches!(bytes.first(), Some(b'+' | b'-')));
+            let mut digits = 0;
+            while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+                cursor += 1;
+                digits += 1;
+            }
+            if bytes.get(cursor) == Some(&b'.') {
+                cursor += 1;
+                while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+                    cursor += 1;
+                    digits += 1;
+                }
+            }
+            if matches!(bytes.get(cursor), Some(b'e' | b'E')) {
+                cursor += 1;
+                if matches!(bytes.get(cursor), Some(b'+' | b'-')) {
+                    cursor += 1;
+                }
+                let exponent_start = cursor;
+                while matches!(bytes.get(cursor), Some(b'0'..=b'9')) {
+                    cursor += 1;
+                }
+                if cursor == exponent_start {
+                    return f64::NAN;
+                }
+            }
+            if digits == 0 || cursor != bytes.len() {
+                return f64::NAN;
+            }
+            return value.parse().unwrap_or(f64::NAN);
+        };
+
+    if digits.is_empty() {
+        return f64::NAN;
+    }
+    let mut number = 0.0;
+    for ch in digits.chars() {
+        let Some(digit) = ch.to_digit(radix) else {
+            return f64::NAN;
+        };
+        number = number * radix as f64 + digit as f64;
+    }
+    number
+}
+
+fn render_number(value: f64) -> String {
+    if !value.is_finite() {
+        return "null".to_owned();
+    }
+    if value == 0.0 {
+        return "0".to_owned();
+    }
+
+    let sign = if value.is_sign_negative() { "-" } else { "" };
+    let raw = value.abs().to_string();
+    let (mantissa, exponent) = raw
+        .split_once('e')
+        .or_else(|| raw.split_once('E'))
+        .map_or((raw.as_str(), 0), |(mantissa, exponent)| {
+            (mantissa, exponent.parse::<i32>().unwrap())
+        });
+    let decimal = mantissa.find('.').unwrap_or(mantissa.len()) as i32;
+    let mut digits: String = mantissa.chars().filter(|ch| *ch != '.').collect();
+    let leading_zeroes = digits.chars().take_while(|ch| *ch == '0').count();
+    digits.drain(..leading_zeroes);
+    let n = decimal + exponent - leading_zeroes as i32;
+    while digits.ends_with('0') {
+        digits.pop();
+    }
+    let k = digits.len() as i32;
+
+    let body = if k <= n && n <= 21 {
+        format!("{digits}{}", "0".repeat((n - k) as usize))
+    } else if 0 < n && n <= 21 {
+        let split = n as usize;
+        format!("{}.{}", &digits[..split], &digits[split..])
+    } else if -6 < n && n <= 0 {
+        format!("0.{}{}", "0".repeat((-n) as usize), digits)
+    } else {
+        let exponent = n - 1;
+        let fraction = if digits.len() == 1 {
+            digits
+        } else {
+            format!("{}.{}", &digits[..1], &digits[1..])
+        };
+        if exponent >= 0 {
+            format!("{fraction}e+{exponent}")
+        } else {
+            format!("{fraction}e{exponent}")
+        }
+    };
+    format!("{sign}{body}")
+}
 
