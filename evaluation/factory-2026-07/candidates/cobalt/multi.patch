             '\\' => out.push_str("\\\\"),
             '"' => out.push_str("\\\""),
+            '\u{0008}' => out.push_str("\\b"),
+            '\u{000c}' => out.push_str("\\f"),
             '\n' => out.push_str("\\n"),
             '\r' => out.push_str("\\r"),
             '\t' => out.push_str("\\t"),
+            c if c <= '\u{001f}' => {
+                let value = c as usize;
+                out.push_str("\\u00");
+                out.push(HEX[value >> 4] as char);
+                out.push(HEX[value & 0x0f] as char);
+            }
             c => out.push(c),
         }
     }
