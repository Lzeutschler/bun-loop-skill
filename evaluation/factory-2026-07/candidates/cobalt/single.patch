diff --git a/port/src/ops/escaped_pairs.rs b/port/src/ops/escaped_pairs.rs
index cc4ebaa..dbc0f22 100644
--- a/port/src/ops/escaped_pairs.rs
+++ b/port/src/ops/escaped_pairs.rs
@@ -1,6 +1,50 @@
 pub fn run(input: &str) -> Vec<String> {
-    input.split(';').map(|entry| {
-        let (key, value) = entry.split_once('=').unwrap_or((entry, ""));
-        format!("{key}:{value}")
-    }).collect()
+    fn split_escaped(input: &str, delimiter: char) -> Vec<String> {
+        let mut result = Vec::new();
+        let mut current = String::new();
+        let mut escaped = false;
+
+        for ch in input.chars() {
+            if escaped {
+                current.push(ch);
+                escaped = false;
+            } else if ch == '\\' {
+                escaped = true;
+            } else if ch == delimiter {
+                result.push(current);
+                current = String::new();
+            } else {
+                current.push(ch);
+            }
+        }
+
+        if escaped {
+            current.push('\\');
+        }
+        result.push(current);
+        result
+    }
+
+    split_escaped(input, ';')
+        .into_iter()
+        .map(|entry| {
+            let mut pair = split_escaped(&entry, '=').into_iter();
+            let key = pair.next().unwrap_or_default();
+            format!("{key}:{}", pair.collect::<Vec<_>>().join("="))
+        })
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn applies_both_escape_layers() {
+        assert_eq!(
+            run("name=cobalt;note=left\\=right;empty="),
+            ["name:cobalt", "note:left=right", "empty:"]
+        );
+        assert_eq!(run("a\\;b=c"), ["a;b:c"]);
+    }
 }
diff --git a/port/src/ops/floor_bucket.rs b/port/src/ops/floor_bucket.rs
index 934b882..34297e1 100644
--- a/port/src/ops/floor_bucket.rs
+++ b/port/src/ops/floor_bucket.rs
@@ -1 +1,22 @@
-pub fn run(value: i64, width: i64) -> i64 { value / width }
+pub fn run(value: i64, width: i64) -> i64 {
+    let quotient = value / width;
+    let remainder = value % width;
+    if remainder != 0 && (value < 0) != (width < 0) {
+        quotient - 1
+    } else {
+        quotient
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn rounds_toward_negative_infinity() {
+        assert_eq!(run(-16, 5), -4);
+        assert_eq!(run(16, -5), -4);
+        assert_eq!(run(-16, -5), 3);
+        assert_eq!(run(-15, 5), -3);
+    }
+}
