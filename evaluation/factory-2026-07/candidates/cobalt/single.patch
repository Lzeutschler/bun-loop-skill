diff --git a/port/src/ops/window.rs b/port/src/ops/window.rs
index 11e6f16..aa67140 100644
--- a/port/src/ops/window.rs
+++ b/port/src/ops/window.rs
@@ -1,5 +1,34 @@
 pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+    let chars: Vec<char> = input.chars().collect();
+    let length = chars.len() as i128;
+    let start = start as i128;
+    let end = start + count as i128;
+
+    fn slice_index(index: i128, length: i128) -> usize {
+        if index < 0 {
+            (length + index).max(0) as usize
+        } else {
+            index.min(length) as usize
+        }
+    }
+
+    let begin = slice_index(start, length);
+    let end = slice_index(end, length);
+    chars[begin..end.max(begin)].iter().collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn slices_unicode_code_points() {
+        assert_eq!(run("A🙂Bécobalt", 1, 3), "🙂Bé");
+    }
+
+    #[test]
+    fn normalizes_negative_bounds_independently() {
+        assert_eq!(run("cobalt", -9, 4), "c");
+        assert_eq!(run("cobalt", -2, 1), "l");
+    }
 }
