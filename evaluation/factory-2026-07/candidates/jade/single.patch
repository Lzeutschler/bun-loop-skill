diff --git a/port/src/ops/escaped_fields.rs b/port/src/ops/escaped_fields.rs
index a56fc45..e11c2c6 100644
--- a/port/src/ops/escaped_fields.rs
+++ b/port/src/ops/escaped_fields.rs
@@ -1,3 +1,48 @@
-pub fn run(input: &str, delimiter: char) -> Vec<String> {
-    input.split(delimiter).map(str::to_owned).collect()
+pub fn run(input: &str, delimiter: &str) -> Vec<String> {
+    let mut delimiter_chars = delimiter.chars();
+    let delimiter = match (delimiter_chars.next(), delimiter_chars.next()) {
+        (Some(ch), None) => Some(ch),
+        _ => None,
+    };
+    let mut result = Vec::new();
+    let mut current = String::new();
+    let mut escaped = false;
+
+    for ch in input.chars() {
+        if escaped {
+            current.push(ch);
+            escaped = false;
+        } else if ch == '\\' {
+            escaped = true;
+        } else if Some(ch) == delimiter {
+            result.push(current);
+            current = String::new();
+        } else {
+            current.push(ch);
+        }
+    }
+
+    if escaped {
+        current.push('\\');
+    }
+    result.push(current);
+    result
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn splits_unescaped_delimiters() {
+        assert_eq!(run("one|two\\|inner|jade", "|"), ["one", "two|inner", "jade"]);
+        assert_eq!(run("a\\", "|"), ["a\\"]);
+        assert_eq!(run("a🙂b🙂", "🙂"), ["a", "b", ""]);
+    }
+
+    #[test]
+    fn a_non_character_delimiter_never_matches() {
+        assert_eq!(run("a|b", ""), ["a|b"]);
+        assert_eq!(run("a|b", "||"), ["a|b"]);
+    }
 }
