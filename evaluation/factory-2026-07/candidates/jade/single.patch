+        let values = ["zeta", "jade", "--", "alpha", "zeta", "--"].map(str::to_owned);
+        assert_eq!(run(&values), ["zeta", "jade", "alpha", "--"]);
+    }
+
+    #[test]
+    fn missing_separator_keeps_all_unique_values() {
+        let values = ["b", "a", "b"].map(str::to_owned);
+        assert_eq!(run(&values), ["b", "a"]);
+    }
 }
