+            ["name:jade", "note:left=right", "empty:"]
+        );
+        assert_eq!(run("a=b=c;bare"), ["a:b=c", "bare:"]);
+    }
 }
diff --git a/port/src/ops/floor_bucket.rs b/port/src/ops/floor_bucket.rs
index 934b882..c0f8b1e 100644
--- a/port/src/ops/floor_bucket.rs
+++ b/port/src/ops/floor_bucket.rs
@@ -1 +1,24 @@
-pub fn run(value: i64, width: i64) -> i64 { value / width }
+pub fn run(value: i64, width: i64) -> i64 {
+    let value = value as i128;
+    let width = width as i128;
+    let quotient = value / width;
+    let remainder = value % width;
+
+    (if remainder != 0 && (value < 0) != (width < 0) {
+        quotient - 1
+    } else {
+        quotient
+    }) as i64
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn rounds_toward_negative_infinity() {
+        assert_eq!(run(-22, 7), -4);
+        assert_eq!(run(22, -7), -4);
+        assert_eq!(run(-21, 7), -3);
+    }
+}
