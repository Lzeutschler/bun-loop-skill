diff --git a/port/src/ops/tail.rs b/port/src/ops/tail.rs
index ed88839..1c3fbc4 100644
--- a/port/src/ops/tail.rs
+++ b/port/src/ops/tail.rs
@@ -1,4 +1,22 @@
-pub fn run(input: &str, count: usize) -> String {
-    let bytes = input.as_bytes();
-    String::from_utf8_lossy(&bytes[bytes.len().saturating_sub(count)..]).into_owned()
+pub fn run(input: &str, count: i64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let requested_start = -(count as i128);
+    let start = if requested_start < 0 {
+        (chars.len() as i128 + requested_start).max(0) as usize
+    } else {
+        requested_start.min(chars.len() as i128) as usize
+    };
+    chars[start..].iter().collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn follows_slice_for_unicode_zero_and_negative_counts() {
+        assert_eq!(run("naïve-jade-🚀", 3), "e-🚀");
+        assert_eq!(run("jade", 0), "jade");
+        assert_eq!(run("jade", -2), "de");
+    }
 }
diff --git a/port/src/ops/window.rs b/port/src/ops/window.rs
index 11e6f16..f25df45 100644
--- a/port/src/ops/window.rs
+++ b/port/src/ops/window.rs
@@ -1,5 +1,32 @@
-pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+fn slice_index(index: i128, len: usize) -> usize {
+    if index < 0 {
+        (len as i128 + index).max(0) as usize
+    } else {
+        index.min(len as i128) as usize
+    }
+}
+
+pub fn run(input: &str, start: i64, count: i64) -> String {
+    let chars: Vec<char> = input.chars().collect();
+    let begin = slice_index(start as i128, chars.len());
+    let end = slice_index(start as i128 + count as i128, chars.len());
+
+    if end <= begin {
+        String::new()
+    } else {
+        chars[begin..end].iter().collect()
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn slices_code_points_and_normalizes_each_bound() {
+        assert_eq!(run("A🙂Béjade", 1, 3), "🙂Bé");
+        assert_eq!(run("abc", -5, 2), "");
+        assert_eq!(run("abc", -4, 3), "ab");
+        assert_eq!(run("abc", 1, -1), "");
+    }
 }
