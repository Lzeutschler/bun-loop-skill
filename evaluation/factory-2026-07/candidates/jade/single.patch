+use std::collections::HashSet;
+
 pub fn run(values: &[String]) -> Vec<String> {
-    let split = values.iter().position(|v| v == "--").unwrap_or(values.len());
-    let mut result = values[..split].iter().chain(values.get(split + 1..).unwrap_or(&[])).cloned().collect::<Vec<_>>();
-    result.sort();
-    result.dedup();
-    result
+    let split = values.iter().position(|value| value == "--");
+    let merged: Box<dyn Iterator<Item = &String>> = match split {
+        Some(index) => Box::new(values[..index].iter().chain(values[index + 1..].iter())),
+        None => Box::new(values.iter()),
+    };
+    let mut seen = HashSet::new();
+    merged
+        .filter(|value| seen.insert(value.as_str()))
+        .cloned()
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
