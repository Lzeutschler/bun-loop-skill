diff --git a/port/src/ops/escaped_fields.rs b/port/src/ops/escaped_fields.rs
index a56fc45..1b74a34 100644
--- a/port/src/ops/escaped_fields.rs
+++ b/port/src/ops/escaped_fields.rs
@@ -1,3 +1,40 @@
 pub fn run(input: &str, delimiter: char) -> Vec<String> {
-    input.split(delimiter).map(str::to_owned).collect()
+    let mut fields = Vec::new();
+    let mut current = String::new();
+    let mut escaped = false;
+
+    for ch in input.chars() {
+        if escaped {
+            current.push(ch);
+            escaped = false;
+        } else if ch == '\\' {
+            escaped = true;
+        } else if ch == delimiter {
+            fields.push(current);
+            current = String::new();
+        } else {
+            current.push(ch);
+        }
+    }
+
+    if escaped {
+        current.push('\\');
+    }
+    fields.push(current);
+    fields
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn splits_unescaped_delimiters_and_unescapes_characters() {
+        assert_eq!(run(r"one\,two,three\four", ','), ["one,two", "threefour"]);
+    }
+
+    #[test]
+    fn preserves_empty_fields_and_a_trailing_escape() {
+        assert_eq!(run(",end\\", ','), ["", "end\\"]);
+    }
 }
diff --git a/port/src/ops/escaped_pairs.rs b/port/src/ops/escaped_pairs.rs
index cc4ebaa..b2b85e0 100644
--- a/port/src/ops/escaped_pairs.rs
+++ b/port/src/ops/escaped_pairs.rs
@@ -1,6 +1,25 @@
 pub fn run(input: &str) -> Vec<String> {
-    input.split(';').map(|entry| {
-        let (key, value) = entry.split_once('=').unwrap_or((entry, ""));
-        format!("{key}:{value}")
-    }).collect()
+    super::escaped_fields::run(input, ';')
+        .into_iter()
+        .map(|entry| {
+            let mut pair = super::escaped_fields::run(&entry, '=');
+            let key = pair.remove(0);
+            format!("{key}:{}", pair.join("="))
+        })
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn parses_escaped_pair_separators_and_multiple_equals() {
+        assert_eq!(run(r"first=1\;2;second=a=b"), ["first:1;2", "second:a=b"]);
+    }
+
+    #[test]
+    fn matches_the_reference_two_stage_unescaping() {
+        assert_eq!(run(r"a\=b;c\\=d"), ["a:b", "c=d:"]);
+    }
 }
diff --git a/port/src/ops/floor_bucket.rs b/port/src/ops/floor_bucket.rs
index 934b882..42f57c6 100644
--- a/port/src/ops/floor_bucket.rs
+++ b/port/src/ops/floor_bucket.rs
@@ -1 +1,23 @@
-pub fn run(value: i64, width: i64) -> i64 { value / width }
+pub fn run(value: i64, width: i64) -> i64 {
+    let quotient = value / width;
+    let remainder = value % width;
+
+    if remainder != 0 && (value < 0) != (width < 0) {
+        quotient - 1
+    } else {
+        quotient
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn rounds_toward_negative_infinity() {
+        assert_eq!(run(-22, 7), -4);
+        assert_eq!(run(22, -7), -4);
+        assert_eq!(run(-22, -7), 3);
+        assert_eq!(run(21, 7), 3);
+    }
+}
