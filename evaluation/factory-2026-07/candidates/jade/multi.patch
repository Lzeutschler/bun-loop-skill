diff --git a/port/src/ops/tail.rs b/port/src/ops/tail.rs
index ed88839..b567144 100644
--- a/port/src/ops/tail.rs
+++ b/port/src/ops/tail.rs
@@ -1,4 +1,12 @@
 pub fn run(input: &str, count: usize) -> String {
-    let bytes = input.as_bytes();
-    String::from_utf8_lossy(&bytes[bytes.len().saturating_sub(count)..]).into_owned()
+    let chars: Vec<char> = input.chars().collect();
+
+    // In JavaScript, -0 is still a zero slice index, so requesting a tail of
+    // zero returns the entire input.
+    let begin = if count == 0 {
+        0
+    } else {
+        chars.len().saturating_sub(count)
+    };
+    chars[begin..].iter().collect()
 }
diff --git a/port/src/ops/window.rs b/port/src/ops/window.rs
index 11e6f16..1c58b29 100644
--- a/port/src/ops/window.rs
+++ b/port/src/ops/window.rs
@@ -1,5 +1,20 @@
 pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+    let chars: Vec<char> = input.chars().collect();
+    let len = chars.len() as i128;
+
+    // JavaScript's slice normalizes the start and end independently.  This
+    // matters when a negative start lies farther left than the input: the end
+    // can still remain negative even though the start has clamped to zero.
+    let normalize = |index: i128| -> usize {
+        if index < 0 {
+            (len + index).max(0) as usize
+        } else {
+            index.min(len) as usize
+        }
+    };
+
+    let start = start as i128;
+    let begin = normalize(start);
+    let end = normalize(start + count as i128);
+    chars[begin..end.max(begin)].iter().collect()
 }
diff --git a/port/src/ops/wrap_index.rs b/port/src/ops/wrap_index.rs
index abc3ff4..6d5d113 100644
--- a/port/src/ops/wrap_index.rs
+++ b/port/src/ops/wrap_index.rs
@@ -1 +1,22 @@
-pub fn run(value: i64, size: i64) -> i64 { value % size }
+pub fn run(value: i64, size: i64) -> i64 {
+    let remainder = value % size;
+
+    if (remainder < 0 && size > 0) || (remainder > 0 && size < 0) {
+        remainder + size
+    } else {
+        remainder
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::run;
+
+    #[test]
+    fn wraps_with_the_size_sign() {
+        assert_eq!(run(-9, 11), 2);
+        assert_eq!(run(13, 11), 2);
+        assert_eq!(run(9, -11), -2);
+        assert_eq!(run(22, 11), 0);
+    }
+}
