+fn is_js_whitespace(ch: char) -> bool {
+    matches!(
+        ch,
+        '\u{0009}'..='\u{000d}'
+            | '\u{0020}'
+            | '\u{00a0}'
+            | '\u{1680}'
+            | '\u{2000}'..='\u{200a}'
+            | '\u{2028}'
+            | '\u{2029}'
+            | '\u{202f}'
+            | '\u{205f}'
+            | '\u{3000}'
+            | '\u{feff}'
+    )
+}
+
+fn parse_prefixed_integer(digits: &str, bits_per_digit: usize) -> Option<f64> {
+    let digit_value = |byte: u8| match byte {
+        b'0'..=b'9' => Some(byte - b'0'),
+        b'a'..=b'f' => Some(byte - b'a' + 10),
+        b'A'..=b'F' => Some(byte - b'A' + 10),
+        _ => None,
+    };
+    let radix = 1_u8 << bits_per_digit;
+    let mut values = Vec::with_capacity(digits.len());
+    for byte in digits.bytes() {
+        let value = digit_value(byte)?;
+        if value >= radix {
+            return None;
+        }
+        values.push(value);
+    }
+    if values.is_empty() {
+        return None;
+    }
+
+    let first = values.iter().position(|&value| value != 0);
+    let Some(first) = first else { return Some(0.0) };
+    let first_bits = (8 - values[first].leading_zeros()) as usize;
+    let bit_length = first_bits + (values.len() - first - 1) * bits_per_digit;
+
+    let mut significand = 0_u64;
+    let mut bit_index = 0_usize;
+    let mut guard = false;
+    let mut sticky = false;
+    for (offset, &value) in values[first..].iter().enumerate() {
+        let width = if offset == 0 { first_bits } else { bits_per_digit };
+        for shift in (0..width).rev() {
+            let bit = (value >> shift) & 1;
+            if bit_index < 53 {
+                significand = (significand << 1) | u64::from(bit);
+            } else if bit_index == 53 {
+                guard = bit != 0;
+            } else if bit != 0 {
+                sticky = true;
+            }
+            bit_index += 1;
+        }
+    }
+
+    if bit_length <= 53 {
+        return Some(significand as f64);
+    }
+    if guard && (sticky || significand & 1 != 0) {
+        significand += 1;
+    }
+
+    let mut exponent = bit_length - 1;
+    if significand == 1_u64 << 53 {
+        significand >>= 1;
+        exponent += 1;
+    }
+    if exponent > 1023 {
+        return Some(f64::INFINITY);
+    }
+
+    let fraction = significand - (1_u64 << 52);
+    Some(f64::from_bits((((exponent + 1023) as u64) << 52) | fraction))
+}
+
+fn is_decimal_number(value: &str) -> bool {
+    let bytes = value.as_bytes();
+    let mut index = usize::from(
+        bytes
+            .first()
+            .is_some_and(|byte| matches!(*byte, b'+' | b'-')),
+    );
+    let integer_start = index;
+    while bytes.get(index).is_some_and(|byte| byte.is_ascii_digit()) {
+        index += 1;
+    }
+    let integer_digits = index - integer_start;
+    let mut fraction_digits = 0;
+    if bytes.get(index) == Some(&b'.') {
+        index += 1;
+        let fraction_start = index;
+        while bytes.get(index).is_some_and(|byte| byte.is_ascii_digit()) {
+            index += 1;
+        }
+        fraction_digits = index - fraction_start;
+    }
+    if integer_digits + fraction_digits == 0 {
+        return false;
+    }
+    if bytes
+        .get(index)
+        .is_some_and(|byte| matches!(*byte, b'e' | b'E'))
+    {
+        index += 1;
+        if bytes
+            .get(index)
+            .is_some_and(|byte| matches!(*byte, b'+' | b'-'))
+        {
+            index += 1;
+        }
+        let exponent_start = index;
+        while bytes.get(index).is_some_and(|byte| byte.is_ascii_digit()) {
+            index += 1;
+        }
+        if index == exponent_start {
+            return false;
+        }
+    }
+    index == bytes.len()
+}
+
+fn parse_number(value: &str) -> f64 {
+    let value = value.trim_matches(is_js_whitespace);
+    if value.is_empty() {
+        return 0.0;
+    }
+
+    match value {
+        "Infinity" | "+Infinity" => f64::INFINITY,
+        "-Infinity" => f64::NEG_INFINITY,
+        _ if value.starts_with("0x") || value.starts_with("0X") => {
+            parse_prefixed_integer(&value[2..], 4).unwrap_or(f64::NAN)
+        }
+        _ if value.starts_with("0b") || value.starts_with("0B") => {
+            parse_prefixed_integer(&value[2..], 1).unwrap_or(f64::NAN)
+        }
+        _ if value.starts_with("0o") || value.starts_with("0O") => {
+            parse_prefixed_integer(&value[2..], 3).unwrap_or(f64::NAN)
+        }
+        _ if is_decimal_number(value) => value.parse().unwrap_or(f64::NAN),
+        _ => f64::NAN,
+    }
+}
+
+fn render_finite_number(value: f64) -> String {
+    let raw = value.abs().to_string();
+    let exponent_at = raw.find(['e', 'E']);
+    let (mantissa, exponent) = match exponent_at {
+        Some(index) => (&raw[..index], raw[index + 1..].parse::<isize>().unwrap()),
+        None => (raw.as_str(), 0),
+    };
+    let decimal_at = mantissa.find('.').unwrap_or(mantissa.len());
+    let mut digits: String = mantissa.chars().filter(|&ch| ch != '.').collect();
+    let leading_zeroes = digits.bytes().take_while(|&byte| byte == b'0').count();
+    let decimal_position = decimal_at as isize + exponent - leading_zeroes as isize;
+    digits.drain(..leading_zeroes);
+    while digits.ends_with('0') {
+        digits.pop();
+    }
+
+    let digit_count = digits.len() as isize;
+    let mut output = if digit_count <= decimal_position && decimal_position <= 21 {
+        digits.push_str(&"0".repeat((decimal_position - digit_count) as usize));
+        digits
+    } else if 0 < decimal_position && decimal_position <= 21 {
+        digits.insert(decimal_position as usize, '.');
+        digits
+    } else if -6 < decimal_position && decimal_position <= 0 {
+        format!("0.{}{}", "0".repeat((-decimal_position) as usize), digits)
+    } else {
+        let exponent = decimal_position - 1;
+        if digits.len() > 1 {
+            digits.insert(1, '.');
+        }
+        format!("{digits}e{}{exponent}", if exponent >= 0 { "+" } else { "" })
+    };
+    if value.is_sign_negative() {
+        output.insert(0, '-');
+    }
+    output
+}
 
