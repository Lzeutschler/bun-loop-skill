@@ -1,3 +1,32 @@
-pub fn run(input: &str, delimiter: char) -> Vec<String> {
-    input.split(delimiter).map(str::to_owned).collect()
+pub fn run(input: &str, delimiter: &str) -> Vec<String> {
+    split_escaped(input, delimiter)
+}
+
+pub fn split_escaped(input: &str, delimiter: &str) -> Vec<String> {
+    let mut fields = Vec::new();
+    let mut field = String::new();
+    let mut escaped = false;
+
+    for character in input.chars() {
+        if escaped {
+            field.push(character);
+            escaped = false;
+        } else if character == '\\' {
+            escaped = true;
+        } else if {
+            let mut encoded = [0; 4];
+            character.encode_utf8(&mut encoded) == delimiter
+        } {
+            fields.push(field);
+            field = String::new();
+        } else {
+            field.push(character);
+        }
+    }
+
+    if escaped {
+        field.push('\\');
+    }
+    fields.push(field);
+    fields
 }
