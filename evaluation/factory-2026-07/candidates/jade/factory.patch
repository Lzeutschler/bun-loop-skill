-pub fn run(input: &str, count: usize) -> String {
-    let bytes = input.as_bytes();
-    String::from_utf8_lossy(&bytes[bytes.len().saturating_sub(count)..]).into_owned()
+pub fn run(input: &str, count: f64) -> String {
+    let length = input.chars().count();
+    let relative_start = (-count).trunc();
+    let start = if relative_start.is_nan()
+        || relative_start == 0.0
+        || relative_start == f64::NEG_INFINITY
+    {
+        0
+    } else if relative_start == f64::INFINITY {
+        length
+    } else if relative_start < 0.0 {
+        length.saturating_sub((-relative_start) as usize)
+    } else {
+        (relative_start as usize).min(length)
+    };
+
+    input.chars().skip(start).collect()
 }
diff --git a/port/src/ops/window.rs b/port/src/ops/window.rs
index 11e6f16..715f07c 100644
--- a/port/src/ops/window.rs
+++ b/port/src/ops/window.rs
@@ -1,5 +1,29 @@
-pub fn run(input: &str, start: isize, count: usize) -> String {
-    let bytes = input.as_bytes();
-    let begin = if start < 0 { bytes.len().saturating_sub((-start) as usize) } else { start as usize };
-    String::from_utf8_lossy(&bytes[begin.min(bytes.len())..(begin + count).min(bytes.len())]).into_owned()
+pub fn run(input: &str, start: f64, count: f64) -> String {
+    let len = input.chars().count();
+    let normalize = |value: f64| {
+        let integer = value.trunc();
+        if integer.is_nan() || integer == 0.0 {
+            0
+        } else if integer < 0.0 {
+            if integer <= -(len as f64) {
+                0
+            } else {
+                (len as f64 + integer) as usize
+            }
+        } else if integer >= len as f64 {
+            len
+        } else {
+            integer as usize
+        }
+    };
+    let begin = normalize(start);
+
+    // JavaScript adds the arguments as IEEE-754 Numbers before normalizing the end.
+    let end = normalize(start + count);
+
+    input
+        .chars()
+        .skip(begin)
+        .take(end.saturating_sub(begin))
+        .collect()
 }
